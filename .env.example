# OpenAI — required for AgentLab API features (diff behavioral summary, run suggestions)
OPENAI_API_KEY="sk-..."
# Optional override for those API calls (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o"

# Only if your target agent code uses Groq (not used by the AgentLab API for summaries/suggestions)
# GROQ_API_KEY="gsk_..."

# Langfuse tracing
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_HOST="http://localhost:3000"
