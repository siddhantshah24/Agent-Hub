# OpenAI — required for AgentLab API features (diff behavioral summary, run suggestions)
OPENAI_API_KEY="sk-..."
# Optional override for those API calls (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o"

# Only if your target agent code uses Groq (not used by the AgentLab API for summaries/suggestions)
# GROQ_API_KEY="gsk_..."

# Langfuse tracing (required for Run → Traces tab in the UI)
# Same keys as `agentlab eval` — put this file at the workspace root OR agent_lab/.env
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_SECRET_KEY="sk-lf-..."
# Self-hosted: run Langfuse on 3000, or use https://cloud.langfuse.com with cloud keys
LANGFUSE_HOST="http://localhost:3000"

# Traces not loading locally?
# 1) Langfuse must be running if LANGFUSE_HOST is localhost:3000 (docker compose up).
# 2) Restart the FastAPI server after editing .env.
# 3) Re-run `agentlab eval` with keys set so SQLite gets `langfuse_trace_id` per sample.
